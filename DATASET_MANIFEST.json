{
  "dataset_name": "kassow-kr810-trajectory-tier0-tier4",
  "version": "1.0.0",
  "status": "scaffold",
  "scope": {
    "tiers_included": [
      "tier0_kinematics_validation",
      "tier1_point_dls",
      "tier2_sequential_dls",
      "tier3_trajectory_tracking",
      "tier4_joint_feasibility_smoothness"
    ],
    "includes_dynamic_control": false,
    "includes_ppo": false,
    "includes_mpdik": false,
    "includes_mappo": false
  },
  "robot": {
    "name": "Kassow KR810",
    "degrees_of_freedom": 7,
    "simulation_engine": "MuJoCo"
  },
  "assets": {
    "status": "integrated",
    "model_path": "assets/kr810.xml",
    "urdf_path": "assets/kr810.urdf",
    "mesh_path": "assets/meshes/a810",
    "n_joints": 7,
    "end_effector_site": "ee_site",
    "conversion_method": "mujoco_builtin_urdf_importer_mj_saveLastXML"
  },
  "conventions": {
    "position_unit": "meter",
    "joint_angle_unit": "radian",
    "orientation_report_unit": "degree",
    "quaternion_order": "wxyz",
    "rotation_error_type": "so3_log"
  },
  "benchmark_status": "not_generated",
  "trajectories_status": "not_generated",
  "acceptance_criteria": {
    "note": "The following thresholds are project-defined acceptance criteria for this dataset's own evaluation pipeline. They are not ISO 9283 certification limits and no ISO 9283 certification is claimed.",
    "kinematic_position_rmse_target_mm": 4.0,
    "kinematic_position_p95_target_mm": 6.0,
    "kinematic_position_max_target_mm": 10.0,
    "orientation_p95_target_deg": 10.0
  },
  "notes": [
    "Stage 2 integrated the KR810 asset pipeline: assets/kr810.urdf, assets/meshes/a810/*.stl, and assets/kr810.xml are populated and load in MuJoCo (see assets/ASSET_CONVERSION_REPORT.md and assets/model_metadata.json). This is asset/model integration only; no Tier 0 kinematic validation, benchmark, or trajectory generation has been performed."
  ]
}
